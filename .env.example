# ===== Konfigurasi Turnitin Core API (TCA) =====
# Salin file ini menjadi ".env" lalu isi nilainya.
#
# TCA_BASE_URL : URL tenant Turnitin Anda, TANPA garis miring di akhir.
#                Contoh: https://namatenant.turnitin.com
# TCA_API_KEY  : API key dari admin console Turnitin (TCA / iThenticate v2).
# TCA_OWNER_ID : ID unik pemilik submission (bebas, konsisten per pengguna).
#
# Jika TCA_BASE_URL / TCA_API_KEY dikosongkan, server berjalan dalam MODE DEMO
# (hasil simulasi, tidak memanggil Turnitin sama sekali).

TCA_BASE_URL=
TCA_API_KEY=
TCA_OWNER_ID=pemilik-utama
PORT=3000
